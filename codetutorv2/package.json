{
  "name": "codetutorv2",
  "displayName": "Code Tutor V2",
  "description": "An AI-powered programming tutor for VS Code that provides progressive feedback, explanations, and exercises",
  "version": "0.0.2",
  "publisher": "MediacollegeAmsterdam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MediacollegeAmsterdam/code-tutorv-v2"
  },
  "bugs": {
    "url": "https://github.com/MediacollegeAmsterdam/code-tutorv-v2/issues"
  },
  "homepage": "https://github.com/MediacollegeAmsterdam/code-tutorv-v2#readme",
  "main": "./dist/extension.js",
  "icon": "resources/icon.png",
  "keywords": [
    "vscode",
    "extension",
    "education",
    "ai",
    "copilot",
    "chat-participant",
    "programming-education"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:csharp",
    "onLanguage:cpp",
    "onLanguage:c",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:php",
    "onLanguage:ruby"
  ],
  "contributes": {
    "chatParticipants": [
      {
        "id": "codetutorv2.tutor",
        "name": "tutor",
        "fullName": "Code Tutor",
        "description": "An AI-powered programming tutor that helps students learn to code with progressive feedback and interactive exercises",
        "isSticky": true,
        "commands": [
          {
            "name": "explain",
            "description": "Explain code concepts or syntax with year-level appropriate explanations"
          },
          {
            "name": "feedback",
            "description": "Get progressive feedback on your code using the Socratic method"
          },
          {
            "name": "exercise",
            "description": "Generate or list programming exercises tailored to your level"
          },
          {
            "name": "level",
            "description": "Change your difficulty level (1-4 based on your year)"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run check-types && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.1.0",
    "jest": "^29.6.1",
    "jest-environment-node": "^29.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@jest/globals": "^30.2.0"
  }
}
